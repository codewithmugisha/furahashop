{
  "name": "ecommerce",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/store"
  ],
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev:store": "npm run dev --workspace=apps/store",
    "build:store": "npm run build --workspace=apps/store",
    "dev": "npm run dev:store",
    "seed": "node prisma/seed.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name add_store_tables",
    "prisma:studio": "npx prisma studio",
    "whatsapp:worker": "node whatsapp-worker.js",
    "dev:all": "concurrently \"npm run dev:store\" \"npm run whatsapp:worker\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.10.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "whatsapp-web.js": "^1.34.7"
  }
}
